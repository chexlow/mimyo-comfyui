# 로컬 launch.ts 가 읽는 시크릿 템플릿. 복사해서 trainer/.env 로 쓰고 채운다.
# .env 는 git 에서 제외된다. 절대 커밋하지 말 것.
#
#   cp trainer/.env.example trainer/.env
#   # 값 채우고
#   set -a; source trainer/.env; set +a
#   bun trainer/scripts/launch.ts ...

# RunPod 콘솔 → Settings → API Keys 에서 생성
RUNPOD_API_KEY=

# AWS 자격증명은 보통 ~/.aws/credentials [runpod] 섹션에 두면 된다.
# 여기 직접 넣을 거면 아래 두 줄만 채우고 launch.ts 는 그대로 동작한다.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# HuggingFace 토큰 (mirror-base.sh 가 private repo 받을 때만 필요)
# HF_TOKEN=

# 선택: 트레이너 이미지 / GPU type override
# TRAINER_IMAGE=actmkan/mimyo-trainer:0.0.1
# GPU_TYPE_ID=RTX PRO 4500
