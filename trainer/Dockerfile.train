# Z-Image / Qwen-Image LoKr/LoRA training worker
# Target: RunPod GPU pod (RTX PRO 4500 / Blackwell sm_120)

FROM nvidia/cuda:12.8.0-cudnn-devel-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    AWS_S3_MULTIPART_THRESHOLD=64MB \
    AWS_S3_MULTIPART_CHUNKSIZE=128MB \
    AWS_MAX_CONCURRENT_REQUESTS=8

RUN apt-get update && apt-get install -y --no-install-recommends \
        git \
        curl \
        ca-certificates \
        unzip \
        gettext-base \
        python3.11 \
        python3.11-dev \
        python3.11-venv \
        python3-pip \
        build-essential \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/* \
    && update-alternatives --install /usr/bin/python python /usr/bin/python3.11 1 \
    && update-alternatives --install /usr/bin/python3 python3 /usr/bin/python3.11 1

# AWS CLI v2 (S3-compatible RunPod endpoint)
RUN curl -L "https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip" -o /tmp/awscliv2.zip \
    && unzip -q /tmp/awscliv2.zip -d /tmp \
    && /tmp/aws/install \
    && rm -rf /tmp/awscliv2.zip /tmp/aws

# PyTorch 2.6 + CUDA 12.8 (sm_120 Blackwell support)
RUN pip install --upgrade pip wheel \
    && pip install --index-url https://download.pytorch.org/whl/cu128 \
        torch==2.6.0 torchvision==0.21.0

# ai-toolkit
ARG AI_TOOLKIT_REF=main
RUN git clone https://github.com/ostris/ai-toolkit.git /opt/ai-toolkit \
    && cd /opt/ai-toolkit \
    && git checkout ${AI_TOOLKIT_REF} \
    && git submodule update --init --recursive \
    && pip install -r requirements.txt \
    && pip install hf_transfer

# Pin known-good extras (Blackwell). 첫 smoke run 에서 이 조합이 OK 인지 검증한다.
RUN pip install \
        bitsandbytes==0.45.0 \
        xformers==0.0.29 \
        accelerate==1.3.0 \
        safetensors

WORKDIR /workspace

COPY entrypoint.sh /workspace/entrypoint.sh
COPY configs/ /workspace/configs/
RUN chmod +x /workspace/entrypoint.sh

ENTRYPOINT ["/workspace/entrypoint.sh"]
